#!/usr/bin/env bash
# Smedjan CLI wrapper — runs the CLI inside the venv python so psycopg2 + deps
# are available regardless of which shell the operator launches from.
# Adds the agentindex tree to PYTHONPATH so `import smedjan` resolves.
set -euo pipefail

# Worktree layout (see ~/smedjan/runbooks/worktree-architecture.md):
#   FACTORY_REPO holds the smedjan package (pinned to smedjan-factory-v0)
#   VENV_REPO holds the shared venv (on main)
FACTORY_REPO="/Users/anstudio/agentindex-factory"
VENV_REPO="/Users/anstudio/agentindex"
PYTHON="${VENV_REPO}/venv/bin/python3"

if [[ ! -x "${PYTHON}" ]]; then
    echo "smedjan: venv python not found at ${PYTHON}" >&2
    exit 127
fi

export PYTHONPATH="${FACTORY_REPO}${PYTHONPATH:+:${PYTHONPATH}}"
exec "${PYTHON}" -m smedjan.cli "$@"
