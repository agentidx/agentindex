#!/usr/bin/env bash
# Smedjan CLI wrapper — runs the CLI inside the venv python so psycopg2 + deps
# are available regardless of which shell the operator launches from.
# Adds the agentindex tree to PYTHONPATH so `import smedjan` resolves.
set -euo pipefail

REPO="/Users/anstudio/agentindex"
PYTHON="${REPO}/venv/bin/python3"

if [[ ! -x "${PYTHON}" ]]; then
    echo "smedjan: venv python not found at ${PYTHON}" >&2
    exit 127
fi

export PYTHONPATH="${REPO}${PYTHONPATH:+:${PYTHONPATH}}"
exec "${PYTHON}" -m smedjan.cli "$@"
