<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>KeepAlive</key>
	<true/>
	<key>Label</key>
	<string>com.nerq.api</string>
	<key>ProgramArguments</key>
	<array>
		<string>/Users/anstudio/agentindex/venv/bin/python</string>
		<string>-m</string>
		<string>uvicorn</string>
		<string>agentindex.api.discovery:app</string>
		<string>--host</string>
		<string>0.0.0.0</string>
		<string>--port</string>
		<string>8000</string>
		<string>--workers</string>
		<string>8</string>
		<string>--limit-concurrency</string>
		<string>50</string>
		<string>--backlog</string>
		<string>256</string>
		<string>--timeout-keep-alive</string>
		<string>30</string>
	</array>
	<key>RunAtLoad</key>
	<true/>
	<key>SoftResourceLimits</key>
	<dict>
		<key>NumberOfFiles</key>
		<integer>65536</integer>
	</dict>
	<key>StandardErrorPath</key>
	<string>/Users/anstudio/agentindex/logs/api_error.log</string>
	<key>StandardOutPath</key>
	<string>/Users/anstudio/agentindex/logs/api.log</string>
	<key>WorkingDirectory</key>
	<string>/Users/anstudio/agentindex</string>
</dict>
</plist>
